---
import Layout from '../layouts/Layout.astro';

const screenshots = [
  {
    src: "/screenshots/hyprland.png",
    alt: "Mectov Linux running Hyprland with terminal windows and code workspace",
    filename: "hyprland_desktop_workspace.png",
    description: "Hyprland Tiling WM setup showing code editor, terminal, and signature cyan panel."
  },
  {
    src: "/screenshots/kde.png",
    alt: "Mectov Linux KDE Plasma 6 desktop environment with file manager and monitor dashboard",
    filename: "kde_plasma6_brutal_system.png",
    description: "KDE Plasma 6 desktop featuring file browser and system hardware dashboards."
  },
  {
    src: "/screenshots/gaming.png",
    alt: "Mectov Linux running Cyberpunk 2077 with Proton compatibility layer and MangoHud",
    filename: "steam_proton_mangohud_test.png",
    description: "Steam Proton gaming benchmarks. MangoHud overlay tracking active performance."
  }
];
---

<Layout title="Screenshots" description="View raw screenshots of the Mectov Linux desktop environments including Hyprland and KDE Plasma 6.">
  <div class="container gallery-container">
    
    <header class="gallery-header">
      <h1 class="gallery-title">SYS_SCREENSHOTS</h1>
      <p class="gallery-subtitle">> Raw system captures. Zero device mockups. Pure workstation interface.</p>
    </header>

    <!-- Asymmetric masonry-like Grid -->
    <div class="gallery-grid">
      {screenshots.map((shot, idx) => (
        <div class={`window-container idx-${idx}`}>
          <div class="window-titlebar">
            <span class="window-control close-btn">[X]</span>
            <span class="window-control minimize-btn">[-]</span>
            <span class="window-filename">{shot.filename}</span>
          </div>
          <div class="window-content">
            <img 
              src={shot.src} 
              alt={shot.alt} 
              class="gallery-image"
              data-lightbox-trigger={shot.src}
              data-lightbox-alt={shot.alt}
            />
          </div>
          <div class="window-footer">
            <p class="window-caption">> {shot.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Lightbox Overlay (Zero animation, snap only) -->
    <div id="lightbox" class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Screenshot lightbox">
      <div class="lightbox-titlebar">
        <span class="lightbox-filename" id="lightbox-filename">image.png</span>
        <button class="lightbox-close" id="lightbox-close-btn" aria-label="Close lightbox">[CLOSE_X]</button>
      </div>
      <div class="lightbox-content">
        <img id="lightbox-img" src="" alt="" />
      </div>
    </div>

  </div>
</Layout>

<style>
.gallery-container {
  padding-top: 3rem;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.gallery-header {
  border-bottom: 2px solid var(--text-primary);
  padding-bottom: 1rem;
}

.gallery-title {
  font-size: 2.5rem;
  color: var(--accent-cyan);
}

.gallery-subtitle {
  font-family: var(--font-mono);
  color: var(--text-muted);
  font-size: 0.85rem;
  margin-top: 0.5rem;
}

/* Asymmetric grid */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2.5rem;
}

@media (max-width: 900px) {
  .gallery-grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
}

/* Make second item span full width or occupy different height alignment for asymmetry */
.window-container.idx-2 {
  grid-column: span 2;
}

@media (max-width: 900px) {
  .window-container.idx-2 {
    grid-column: span 1;
  }
}

/* Raw Window Manager styling */
.window-container {
  background-color: #000;
  border: 4px solid var(--text-primary);
  box-shadow: 6px 6px 0 var(--accent-red);
  display: flex;
  flex-direction: column;
}

.window-container:hover {
  border-color: var(--accent-cyan);
  box-shadow: 8px 8px 0 var(--accent-red);
}

.window-titlebar {
  background-color: var(--text-primary);
  color: var(--bg-color);
  padding: 0.35rem 0.75rem;
  display: flex;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: bold;
}

.window-control {
  cursor: pointer;
  margin-right: 0.5rem;
}

.window-control.close-btn {
  color: var(--accent-red);
}

.window-filename {
  margin-left: auto;
}

.window-content {
  background-color: #101015;
  overflow: hidden;
  line-height: 0;
  cursor: pointer;
}

.gallery-image {
  width: 100%;
  height: auto;
  border-bottom: 2px solid var(--text-primary);
  transition: transform 0.15s steps(2); /* Choppy snap effect */
}

.window-content:hover .gallery-image {
  transform: scale(1.02);
}

.window-footer {
  padding: 0.75rem 1rem;
  background-color: #000;
  border-top: 2px solid var(--text-primary);
}

.window-caption {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--accent-cyan);
}

/* Lightbox Modal (Instant snap) */
.lightbox-overlay {
  display: none; /* Hidden by default */
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(10, 10, 14, 0.95);
  z-index: 2000;
  flex-direction: column;
  padding: 2rem;
  box-sizing: border-box;
}

.lightbox-overlay.active {
  display: flex;
}

.lightbox-titlebar {
  background-color: var(--accent-red);
  color: #000;
  padding: 0.5rem 1rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-family: var(--font-mono);
  font-weight: bold;
  border: 3px solid #FFF;
  border-bottom: none;
}

.lightbox-close {
  background: none;
  border: none;
  color: #000;
  font-family: var(--font-mono);
  font-weight: bold;
  font-size: 0.9rem;
  cursor: pointer;
}

.lightbox-close:hover {
  background-color: #000;
  color: var(--accent-red);
  padding: 0 0.5rem;
}

.lightbox-content {
  flex: 1;
  border: 3px solid #FFF;
  background-color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 1rem;
}

.lightbox-content img {
  max-width: 100%;
  max-height: 80vh;
  object-fit: contain;
  border: 2px solid var(--text-muted);
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll('[data-lightbox-trigger]');
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxFilename = document.getElementById('lightbox-filename');
    const closeBtn = document.getElementById('lightbox-close-btn');

    if (!lightbox || !lightboxImg || !lightboxFilename || !closeBtn) return;

    images.forEach(img => {
      img.addEventListener('click', () => {
        const src = img.getAttribute('data-lightbox-trigger');
        const alt = img.getAttribute('data-lightbox-alt');
        const container = img.closest('.window-container');
        const filename = container ? container.querySelector('.window-filename')?.textContent : 'image.png';

        if (src) {
          lightboxImg.src = src;
          lightboxImg.alt = alt || '';
          lightboxFilename.textContent = filename || 'image.png';
          lightbox.classList.add('active');
        }
      });
    });

    function closeLightbox() {
      lightbox?.classList.remove('active');
      if (lightboxImg) lightboxImg.src = '';
    }

    closeBtn.addEventListener('click', closeLightbox);
    
    // Close on overlay click outside image
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || e.target === lightbox.querySelector('.lightbox-content')) {
        closeLightbox();
      }
    });

    // Close on Escape key
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeLightbox();
      }
    });
  });
</script>
