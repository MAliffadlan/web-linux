---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Kernel Panic" description="Error 404 - Page not found. System kernel panic.">
  <div class="container error-container">
    
    <!-- Top POST Header -->
    <header class="bios-header">
      <p class="bios-text font-mono-bold">MECTOV OS BOOT SYSTEM V1.0</p>
      <p class="bios-text font-mono">COPYRIGHT (C) 2026 MECTOV LTD.</p>
    </header>

    <div class="panic-window">
      <div class="panic-titlebar">
        <span class="panic-bullet"></span>
        <span class="panic-title-text">!!! KERNEL PANIC !!!</span>
      </div>
      <div class="panic-body">
        <p class="log-red">[  FAILED  ] Failed to mount target path at virtual block device.</p>
        <p class="log-red">[  FATAL   ] HTTP_STATUS_CODE: 404 (FILE_NOT_FOUND)</p>
        <p class="log-muted">-----------------------------------------------------</p>
        <p class="dump-line">Call Trace:</p>
        <p class="dump-line"> [&lt;0000000000000404&gt;] dump_stack+0x7d/0x9c</p>
        <p class="dump-line"> [&lt;0000000000000000&gt;] panic+0xfc/0x2d0</p>
        <p class="dump-line"> [&lt;f827a0b6e30e87f5&gt;] handle_invalid_request+0x1a4/0x200</p>
        <p class="dump-line"> [&lt;ffffffffa0b3f827&gt;] mectov_http_server_init+0xcb/0x100</p>
        <p class="log-muted">-----------------------------------------------------</p>
        
        <div class="rescue-prompt">
          <p class="rescue-text">grub rescue> <span class="client-path" id="client-path">/invalid-path</span></p>
          <p class="rescue-error">Unknown page path. The system cannot locate the requested sector.</p>
          <p class="rescue-hint">Type '[~]' or click below to return to the root filesystem partition.</p>
        </div>
      </div>
    </div>

    <!-- CTA Button back to home -->
    <div class="cta-center">
      <a href="/" class="btn-brutal return-btn">
        [~] reboot -f /dev/sda1
      </a>
    </div>

  </div>
</Layout>

<style>
.error-container {
  padding-top: 4rem;
  display: flex;
  flex-direction: column;
  gap: 2rem;
  max-width: 800px;
}

.bios-header {
  border-bottom: 2px dashed var(--text-muted);
  padding-bottom: 1rem;
}

.bios-text {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-bottom: 0.25rem;
}

/* Panic Window Wrapper */
.panic-window {
  background-color: #000;
  border: 4px solid var(--accent-red);
  box-shadow: 8px 8px 0 var(--accent-cyan);
}

.panic-titlebar {
  background-color: var(--accent-red);
  color: #000;
  padding: 0.5rem 1rem;
  font-family: var(--font-mono);
  font-weight: bold;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.panic-bullet {
  width: 10px;
  height: 10px;
  background-color: #000;
}

.panic-body {
  padding: 1.5rem;
  font-family: var(--font-mono);
  font-size: 0.85rem;
  line-height: 1.5;
}

.log-red {
  color: var(--accent-red);
  font-weight: bold;
  margin-bottom: 0.25rem;
}

.log-muted {
  color: var(--text-muted);
  margin: 0.75rem 0;
}

.dump-line {
  color: var(--text-primary);
  margin-bottom: 0.25rem;
}

/* Grub rescue simulation */
.rescue-prompt {
  margin-top: 1.5rem;
  background-color: #0c0c14;
  border: 1px solid rgba(255, 42, 75, 0.2);
  padding: 1rem;
}

.rescue-text {
  color: #FFF;
  font-weight: bold;
}

.client-path {
  color: var(--accent-cyan);
}

.client-path::after {
  content: "█";
  color: var(--accent-cyan);
  animation: cursor-blink 1s infinite steps(2, start);
  margin-left: 2px;
}

.rescue-error {
  color: var(--accent-red);
  margin: 0.5rem 0;
}

.rescue-hint {
  color: var(--text-muted);
  font-size: 0.8rem;
}

.cta-center {
  text-align: center;
  margin-top: 1rem;
}

.return-btn {
  background-color: var(--accent-red);
  border-color: var(--accent-red);
  color: #FFF;
  box-shadow: 6px 6px 0 var(--accent-cyan);
}

.return-btn:hover {
  background-color: var(--accent-cyan);
  border-color: var(--accent-cyan);
  color: #000;
  box-shadow: 8px 8px 0 var(--accent-red);
  transform: translate(-4px, -4px);
}

@keyframes cursor-blink {
  to { visibility: hidden; }
}
</style>

<script>
  // Dynamically set the path in the terminal prompt based on browser location
  document.addEventListener('DOMContentLoaded', () => {
    const pathEl = document.getElementById('client-path');
    if (pathEl) {
      pathEl.textContent = window.location.pathname;
    }
  });
</script>
