---
import Layout from '../layouts/Layout.astro';
import GlitchTitle from '../components/GlitchTitle.astro';

// Boot log simulation data
const bootLogs = [
  { status: "OK", text: "Initializing kernel boot sequence..." },
  { status: "OK", text: "Loaded 6.9.12-cachyos-bore kernel modules" },
  { status: "OK", text: "Started CPU microcode updater" },
  { status: "OK", text: "Mounting /sys, /proc, and /dev filesystems" },
  { status: "OK", text: "Activating encrypted swap space..." },
  { status: "OK", text: "Wayland compositor (Hyprland/KDE) ready" },
];
---

<Layout title="mectov linux">
  <div class="container hero-container">
    
    <!-- Top Bar boot simulator -->
    <header class="terminal-post-header">
      <div class="post-col">
        <p class="post-text font-mono-bold">> BIOS V8.42 - MECTOV LTD</p>
        <p class="post-text font-mono">CPU: AMD Ryzen 9 @ 5.70GHz</p>
        <p class="post-text font-mono">RAM: 32768MB OK</p>
      </div>
      <div class="post-col right-align">
        <p class="post-text font-mono-bold">RELEASE: 2026.06.30</p>
        <p class="post-text font-mono">STATUS: SYSTEM_READY</p>
      </div>
    </header>

    <div class="hero-split">
      <!-- Left: Logo & Glitch Header -->
      <section class="hero-left">
        <GlitchTitle text="MECTOV LINUX" tag="h1" />
        <h2 class="subheadline">> Distro built for speed. Powered by Arch & CachyOS.</h2>
        
        <div class="cta-group">
          <a href="/download" class="btn-brutal cta-btn">
            [ISO] Download
          </a>
          <a href="/docs" class="btn-brutal secondary-btn">
            [DOCS] Read Manual
          </a>
        </div>
      </section>

      <!-- Right: Neofetch / Spec Info Badge -->
      <section class="hero-right">
        <div class="terminal-badge">
          <div class="badge-title-bar">
            <span class="badge-title">neofetch --distro mectov</span>
            <span class="badge-close">[X]</span>
          </div>
          <div class="badge-body">
            <p class="badge-user">root@mectov-linux</p>
            <p class="badge-sep">----------------</p>
            <p class="badge-item"><span class="badge-label">OS:</span> Mectov Linux x86_64</p>
            <p class="badge-item"><span class="badge-label">Host:</span> Custom Arch Base</p>
            <p class="badge-item"><span class="badge-label">Kernel:</span> 6.9.12-cachyos-bore (v3-sched)</p>
            <p class="badge-item"><span class="badge-label">Uptime:</span> 13h 37m</p>
            <p class="badge-item"><span class="badge-label">Shell:</span> zsh 5.9</p>
            <p class="badge-item"><span class="badge-label">DE:</span> KDE Plasma 6.1 (Wayland)</p>
            <p class="badge-item"><span class="badge-label">WM:</span> KWin / Hyprland</p>
            <p class="badge-item"><span class="badge-label">Terminal:</span> alacritty</p>
            <p class="badge-item"><span class="badge-label">CPU:</span> AMD Ryzen 9 7950X3D (32) @ 5.7GHz</p>
            <p class="badge-item"><span class="badge-label">GPU:</span> AMD Radeon RX 7900 XTX</p>
            <p class="badge-item"><span class="badge-label">Memory:</span> 4832MiB / 32120MiB (15%)</p>
            
            <div class="color-blocks">
              <span class="color-block black"></span>
              <span class="color-block red"></span>
              <span class="color-block green"></span>
              <span class="color-block yellow"></span>
              <span class="color-block blue"></span>
              <span class="color-block magenta"></span>
              <span class="color-block cyan"></span>
              <span class="color-block white"></span>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Bottom: Simulated Boot Logs -->
    <section class="boot-logs-section">
      <div class="boot-logs-box">
        {bootLogs.map((log) => (
          <div class="log-line">
            <span class="log-status font-mono-bold">[{log.status}]</span>
            <span class="log-text font-mono">{log.text}</span>
          </div>
        ))}
        <div class="log-line prompt-line">
          <span class="log-status font-mono-bold">></span>
          <span class="log-text font-mono typing-cursor">Press '~' to load Matrix Environment. System is fully operational.</span>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
.hero-container {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  padding-top: 3rem;
}

/* Header POST screen style */
.terminal-post-header {
  border-bottom: 2px solid var(--text-primary);
  padding-bottom: 1rem;
  display: flex;
  justify-content: space-between;
  font-size: 0.85rem;
  color: var(--text-muted);
}

.terminal-post-header p {
  margin-bottom: 0.25rem;
}

.right-align {
  text-align: right;
}

/* Hero layout columns */
.hero-split {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 3rem;
  align-items: center;
}

@media (max-width: 900px) {
  .hero-split {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
}

.hero-left {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}


.subheadline {
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--accent-cyan);
  border-left: 4px solid var(--accent-red);
  padding-left: 1rem;
  margin: 0.5rem 0;
}

.cta-group {
  display: flex;
  gap: 1.5rem;
  margin-top: 1rem;
}

@media (max-width: 480px) {
  .cta-group {
    flex-direction: column;
    gap: 1rem;
  }
}

.cta-btn {
  background-color: var(--text-primary);
  color: var(--bg-color);
}

.cta-btn:hover {
  background-color: var(--accent-red);
  color: var(--text-primary);
}

.secondary-btn {
  border-color: var(--accent-cyan);
  box-shadow: 4px 4px 0 var(--accent-cyan);
}

.secondary-btn:hover {
  background-color: var(--accent-cyan);
  border-color: var(--accent-cyan);
  color: var(--bg-color);
  box-shadow: 8px 8px 0 var(--accent-red);
}

/* Neofetch Badge Widget */
.terminal-badge {
  background-color: #000;
  border: 4px solid var(--text-primary);
  box-shadow: 6px 6px 0 var(--accent-red);
}

.badge-title-bar {
  background-color: var(--text-primary);
  color: var(--bg-color);
  display: flex;
  justify-content: space-between;
  padding: 0.25rem 0.75rem;
  font-family: var(--font-mono);
  font-weight: bold;
  font-size: 0.85rem;
}

.badge-body {
  padding: 1.25rem;
  font-family: var(--font-mono);
  font-size: 0.85rem;
}

.badge-user {
  color: var(--accent-cyan);
  font-weight: bold;
}

.badge-sep {
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.badge-item {
  margin-bottom: 0.25rem;
  line-height: 1.3;
}

.badge-label {
  color: var(--accent-red);
  font-weight: bold;
}

/* Color block row */
.color-blocks {
  display: flex;
  gap: 0.25rem;
  margin-top: 1rem;
}

.color-block {
  display: inline-block;
  width: 20px;
  height: 10px;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.color-block.black { background-color: #2e3440; }
.color-block.red { background-color: var(--accent-red); }
.color-block.green { background-color: #a3be8c; }
.color-block.yellow { background-color: #ebcb8b; }
.color-block.blue { background-color: #81a1c1; }
.color-block.magenta { background-color: #b48ead; }
.color-block.cyan { background-color: var(--accent-cyan); }
.color-block.white { background-color: var(--text-primary); }

/* Simulated Boot Logs Box */
.boot-logs-section {
  margin-top: 1rem;
}

.boot-logs-box {
  background-color: #000;
  border: 2px solid var(--text-muted);
  padding: 1rem;
  font-size: 0.85rem;
}

.log-line {
  margin-bottom: 0.35rem;
  display: flex;
  gap: 0.75rem;
}

.log-status {
  color: var(--accent-cyan);
}

.prompt-line .log-status {
  color: var(--accent-red);
}

.typing-cursor {
  position: relative;
}

.typing-cursor::after {
  content: "█";
  color: var(--accent-cyan);
  animation: blink 1s infinite steps(2, start);
  margin-left: 2px;
}

@keyframes blink {
  to { visibility: hidden; }
}

.font-mono {
  font-family: var(--font-mono);
}

.font-mono-bold {
  font-family: var(--font-mono);
  font-weight: bold;
}
</style>
